# ═══════════════════════════════════════
# Facebook Graph API
# ═══════════════════════════════════════
FB_PAGE_ID=你的粉專ID
FB_PAGE_TOKEN=你的Page_Access_Token

# ═══════════════════════════════════════
# Telegram Bot
# ═══════════════════════════════════════
TELEGRAM_BOT_TOKEN=從BotFather取得的Token
TELEGRAM_ADMIN_CHAT_ID=你的Telegram_Chat_ID

# ═══════════════════════════════════════
# LINE Messaging API
# ═══════════════════════════════════════
LINE_CHANNEL_SECRET=LINE_Channel_Secret
LINE_CHANNEL_ACCESS_TOKEN=LINE_Channel_Access_Token

# ═══════════════════════════════════════
# tawk.to 聊天視窗
# ═══════════════════════════════════════
NEXT_PUBLIC_TAWK_PROPERTY_ID=你的tawk_Property_ID
NEXT_PUBLIC_TAWK_WIDGET_ID=你的tawk_Widget_ID

# ═══════════════════════════════════════
# LINE 官方帳號 QR Code（浮動按鈕用）
# ═══════════════════════════════════════
NEXT_PUBLIC_LINE_OA_URL=https://line.me/R/ti/p/@你的ID
NEXT_PUBLIC_LINE_QR_IMAGE=/images/line-qr.png

# ═══════════════════════════════════════
# Webhook 安全驗證
# ═══════════════════════════════════════
WEBHOOK_SECRET=自訂一個隨機字串作為webhook驗證
